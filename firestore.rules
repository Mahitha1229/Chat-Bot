rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    match /logs/{logId} {
      allow read, write: if true;
    }
  }
}