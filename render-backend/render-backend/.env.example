# Groq API key (required) — from https://console.groq.com/keys
GROQ_API_KEY=

# YouTube Data API v3 key (required only if you use the YouTube search feature)
# From https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Firebase service account JSON, base64-encoded onto ONE line (required for Firestore chat logging)
# See README.md "Step 2" for how to generate this.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Comma-separated list of allowed frontend origins, e.g.:
# https://your-app.web.app,https://your-app.firebaseapp.com
# Use * to allow all origins (fine for a personal/portfolio project).
ALLOWED_ORIGINS=*

# Optional — defaults shown
MODEL_NAME=llama-3.1-8b-instant
RATE_LIMIT_RPM=25
RATE_LIMIT_RPD=500
PORT=3001
